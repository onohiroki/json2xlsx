{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anomalyco/sheet2xlsx/schema",
  "title": "Sheet2XLSX JSON Schema",
  "description": "SheetJS 風 JSON から XLSX へ変換するためのスキーマ",
  "oneOf": [
    { "$ref": "#/$defs/singleSheet" },
    { "$ref": "#/$defs/multiSheet" },
    { "$ref": "#/$defs/bookWrapped" }
  ],

  "$defs": {
    "colorValue": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "#RRGGBB 形式の色指定"
    },
    "singleSheet": {
      "type": "object",
      "properties": {
        "name":    { "$ref": "#/$defs/sheetName" },
        "cells":   { "$ref": "#/$defs/cells" },
        "rows":    { "$ref": "#/$defs/rows" },
        "cols":    { "$ref": "#/$defs/cols" },
        "rowDims": { "$ref": "#/$defs/rowDims" },
        "merges":  { "$ref": "#/$defs/merges" },
        "styles":  { "$ref": "#/$defs/styles" }
      },
      "required": ["cells"],
      "additionalProperties": false
    },

    "multiSheet": {
      "type": "object",
      "properties": {
        "sheets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":    { "$ref": "#/$defs/sheetName" },
              "cells":   { "$ref": "#/$defs/cells" },
              "rows":    { "$ref": "#/$defs/rows" },
              "cols":    { "$ref": "#/$defs/cols" },
              "rowDims": { "$ref": "#/$defs/rowDims" },
              "merges":  { "$ref": "#/$defs/merges" }
            },
            "required": ["cells"],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "styles": { "$ref": "#/$defs/styles" }
      },
      "required": ["sheets"],
      "additionalProperties": false
    },

    "sheetName": {
      "type": "string",
      "description": "シート名"
    },

    "cells": {
      "type": "object",
      "description": "キーは A1 形式のセル参照",
      "patternProperties": {
        "^[A-Z]+[1-9][0-9]*$": { "$ref": "#/$defs/cell" }
      },
      "additionalProperties": false
    },

    "cell": {
      "type": "object",
      "description": "セルオブジェクト",
      "properties": {
        "t": { "$ref": "#/$defs/cellType" },
        "v": {},
        "f": { "type": "string", "description": "数式本体（= を含まない）" },
        "z": { "type": "string", "description": "数値書式コード" },
        "s": { "$ref": "#/$defs/styleRef" },
        "l": { "$ref": "#/$defs/hyperlink" }
      },
      "required": ["t"],
      "additionalProperties": false
    },

    "cellType": {
      "type": "string",
      "enum": ["s", "n", "b", "f", "d"],
      "description": "s=文字列, n=数値, b=真偽, f=数式, d=日付"
    },

    "styleRef": {
      "type": "integer",
      "description": "styles[].id への参照"
    },

    "hyperlink": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "target":  { "type": "string" },
            "tooltip": { "type": "string" }
          },
          "required": ["target"],
          "additionalProperties": false
        }
      ]
    },

    "rows": {
      "type": "array",
      "description": "行データ配列（拡張用）",
      "items": {}
    },

    "cols": {
      "type": "array",
      "description": "列幅設定",
      "items": { "$ref": "#/$defs/col" }
    },

    "col": {
      "type": "object",
      "properties": {
        "col":   { "type": "string", "description": "列記号 (A, B, ...)" },
        "width": { "type": "number", "description": "列幅" }
      },
      "required": ["col", "width"],
      "additionalProperties": false
    },

    "rowDims": {
      "type": "array",
      "description": "行高設定",
      "items": { "$ref": "#/$defs/rowDim" }
    },

    "rowDim": {
      "type": "object",
      "properties": {
        "row":    { "type": "integer", "description": "行番号 (1始まり)" },
        "height": { "type": "number",  "description": "行高" }
      },
      "required": ["row", "height"],
      "additionalProperties": false
    },

    "merges": {
      "type": "array",
      "description": "セル結合設定",
      "items": { "$ref": "#/$defs/merge" }
    },

    "merge": {
      "type": "object",
      "properties": {
        "range": { "type": "string", "description": "結合範囲 (例: A1:B1)" }
      },
      "required": ["range"],
      "additionalProperties": false
    },

    "styles": {
      "type": "array",
      "description": "スタイル定義一覧",
      "items": { "$ref": "#/$defs/style" }
    },

    "style": {
      "type": "object",
      "description": "スタイル定義",
      "properties": {
        "id":        { "type": "integer" },
        "fill":      { "$ref": "#/$defs/fill" },
        "border":    { "$ref": "#/$defs/border" },
        "font":      { "$ref": "#/$defs/font" },
        "alignment": { "$ref": "#/$defs/alignment" },
        "numFmt":    { "type": "string", "description": "数値書式コード" }
      },
      "required": ["id"],
      "additionalProperties": false
    },

    "fill": {
      "type": "object",
      "description": "塗りつぶし設定",
      "properties": {
        "type":    { "type": "string", "enum": ["pattern"], "default": "pattern" },
        "pattern": { "type": "integer", "default": 1 },
        "color": {
          "type": "array",
          "description": "色の配列（#RRGGBB 形式）",
          "items": { "$ref": "#/$defs/colorValue" },
          "minItems": 1
        }
      },
      "required": ["type", "pattern", "color"],
      "additionalProperties": false
    },

    "border": {
      "type": "array",
      "description": "罫線設定",
      "items": { "$ref": "#/$defs/borderItem" }
    },

    "borderItem": {
      "type": "object",
      "properties": {
        "side": {
          "type": "string",
          "enum": ["left", "right", "top", "bottom"],
          "description": "省略時は四辺すべてに適用"
        },
        "style": {
          "type": "string",
          "enum": ["thin", "medium", "thick", "dashed", "dotted", "double", "hair", "mediumDashed", "dashDot", "mediumDashDot", "dashDotDot", "mediumDashDotDot", "slantDashDot"]
        },
        "color": { "$ref": "#/$defs/colorValue" }
      },
      "required": ["style", "color"],
      "additionalProperties": false
    },
    "font": {
      "type": "object",
      "description": "フォント設定",
      "properties": {
        "name":   { "type": "string", "default": "Calibri" },
        "size":   { "type": "number", "default": 11 },
        "bold":   { "type": "boolean" },
        "italic": { "type": "boolean" },
        "color":  { "$ref": "#/$defs/colorValue" }
      },
      "additionalProperties": false
    },

    "alignment": {
      "type": "object",
      "description": "セル配置設定",
      "properties": {
        "horizontal": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "vertical": {
          "type": "string",
          "enum": ["top", "center", "bottom"]
        },
        "wrapText": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "bookWrapped": {
      "type": "object",
      "description": "book ラッパー形式（version + book 配下に sheets/charts/props を持つ）",
      "properties": {
        "version": { "type": "string", "description": "スキーマバージョン（例: 0.1）" },
        "book": {
          "type": "object",
          "properties": {
            "props":  { "type": "object", "description": "文書プロパティ（任意）" },
            "sheets": {
              "type": "object",
              "description": "キーがシート名のオブジェクト",
              "additionalProperties": { "$ref": "#/$defs/bookSheet" }
            },
            "charts": {
              "type": "array",
              "description": "グラフオブジェクトの配列",
              "items": { "$ref": "#/$defs/chart" }
            },
            "styles": { "$ref": "#/$defs/styles" }
          },
          "required": ["sheets"],
          "additionalProperties": false
        }
      },
      "required": ["book"],
      "additionalProperties": false
    },

    "bookSheet": {
      "type": "object",
      "description": "book 内のシートオブジェクト（キーがシート名のため name フィールド不要）",
      "properties": {
        "cells":   { "$ref": "#/$defs/cells" },
        "rows":    { "$ref": "#/$defs/rows" },
        "cols":    { "$ref": "#/$defs/cols" },
        "rowDims": { "$ref": "#/$defs/rowDims" },
        "merges":  { "$ref": "#/$defs/merges" }
      },
      "required": ["cells"],
      "additionalProperties": false
    },

    "chart": {
      "type": "object",
      "description": "グラフオブジェクト",
      "properties": {
        "id":     { "type": "string", "description": "一意な識別子（任意）" },
        "t":      { "type": "string", "description": "オブジェクト種別（chart 推奨）" },
        "mode":   { "type": "string", "enum": ["embedded", "chartSheet"], "default": "embedded", "description": "配置モード: embedded(通常シート埋め込み), chartSheet(グラフ専用シート)" },
        "ct":     { "type": "string", "description": "グラフ種別 (col, line, pie ...)" },
        "sheet":  { "type": "string", "description": "配置先シート名" },
        "anchor": { "type": "string", "description": "左上セルアドレス (A1 形式)。chartSheet モードでは無視" },
        "dim":    { "$ref": "#/$defs/chartDim" },
        "title":  { "$ref": "#/$defs/chartTitle" },
        "legend": { "$ref": "#/$defs/chartLegend" },
        "plot":   { "$ref": "#/$defs/chartPlot" },
        "xAxis":  { "$ref": "#/$defs/chartAxis" },
        "yAxis":  { "$ref": "#/$defs/chartAxis" },
        "ser":    {
          "type": "array",
          "items": { "$ref": "#/$defs/chartSeries" },
          "minItems": 1
        },
        "style": { "type": "object" },
        "meta":  { "type": "object" }
      },
      "required": ["ct", "sheet", "ser"],
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "chartSheet" } },
            "required": ["mode"]
          },
          "then": {
            "properties": { "anchor": { "description": "chartSheet モードでは anchor は無視される" } }
          },
          "else": {
            "required": ["anchor"]
          }
        }
      ],
      "additionalProperties": false
    },

    "chartDim": {
      "type": "object",
      "description": "グラフ領域のサイズ・オフセット",
      "properties": {
        "w":    { "type": "number" },
        "h":    { "type": "number" },
        "offx": { "type": "number" },
        "offy": { "type": "number" },
        "sx":   { "type": "number" },
        "sy":   { "type": "number" }
      },
      "additionalProperties": false
    },

    "chartTitle": {
      "type": "object",
      "description": "グラフタイトル",
      "properties": {
        "tx":      { "type": "string" },
        "overlay": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "chartLegend": {
      "type": "object",
      "description": "凡例設定",
      "properties": {
        "show": { "type": "boolean" },
        "pos":  { "type": "string", "enum": ["right", "left", "top", "bottom", "topRight"] }
      },
      "additionalProperties": false
    },

    "chartPlot": {
      "type": "object",
      "description": "プロット領域オプション",
      "properties": {
        "varyColors":   { "type": "boolean" },
        "showBlanksAs": { "type": "string", "enum": ["gap", "zero", "span"] }
      },
      "additionalProperties": false
    },

    "chartAxis": {
      "type": "object",
      "description": "軸設定",
      "properties": {
        "title":          { "type": "string" },
        "minimum":        { "type": ["number", "null"] },
        "maximum":        { "type": ["number", "null"] },
        "majorUnit":      { "type": ["number", "null"] },
        "minorUnit":      { "type": ["number", "null"] },
        "reverseOrder":   { "type": "boolean" },
        "majorGridLines": { "type": "boolean" },
        "minorGridLines": { "type": "boolean" },
        "numFmt":         { "type": "string" }
      },
      "additionalProperties": false
    },

    "chartSeries": {
      "type": "object",
      "description": "データ系列",
      "properties": {
        "name":   { "type": "string" },
        "cat":    { "type": "string" },
        "val":    { "type": "string" },
        "xVal":   { "type": ["string", "null"] },
        "yVal":   { "type": ["string", "null"] },
        "bubble": { "type": ["string", "null"] },
        "line":   { "$ref": "#/$defs/chartLine" },
        "fill":   { "$ref": "#/$defs/chartFill" },
        "marker": { "$ref": "#/$defs/chartMarker" },
        "dLbls":  { "$ref": "#/$defs/chartDLbls" }
      },
      "additionalProperties": false
    },

    "chartLine": {
      "type": "object",
      "description": "系列の線スタイル",
      "properties": {
        "color": { "$ref": "#/$defs/colorValue" },
        "width": { "type": "number" },
        "dash":  { "type": "string" }
      },
      "additionalProperties": false
    },

    "chartFill": {
      "type": "object",
      "description": "系列の塗りつぶし",
      "properties": {
        "color": { "$ref": "#/$defs/colorValue" }
      },
      "additionalProperties": false
    },

    "chartMarker": {
      "type": "object",
      "description": "系列のマーカー設定",
      "properties": {
        "symbol": { "type": "string" },
        "size":   { "type": "number" }
      },
      "additionalProperties": false
    },

    "chartDLbls": {
      "type": "object",
      "description": "データラベル設定",
      "properties": {
        "showVal":       { "type": "boolean" },
        "showCatName":   { "type": "boolean" },
        "showSerName":   { "type": "boolean" },
        "showPercent":   { "type": "boolean" },
        "showLeaderLn":  { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
