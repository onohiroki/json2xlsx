{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/anomalyco/json2xlsx/schema",
  "title": "Json2XLSX JSON Schema",
  "description": "SheetJS 風 JSON から XLSX へ変換するためのスキーマ",
  "oneOf": [
    { "$ref": "#/$defs/singleSheet" },
    { "$ref": "#/$defs/multiSheet" },
    { "$ref": "#/$defs/bookWrapped" }
  ],

  "$defs": {
    "colorValue": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "#RRGGBB 形式の色指定"
    },
    "singleSheet": {
      "type": "object",
      "properties": {
        "name":    { "$ref": "#/$defs/sheetName" },
        "cells":   { "$ref": "#/$defs/cells" },
        "rows":    { "$ref": "#/$defs/rows" },
        "cols":    { "$ref": "#/$defs/cols" },
        "rowDims": { "$ref": "#/$defs/rowDims" },
        "merges":  { "$ref": "#/$defs/merges" },
        "freeze":             { "$ref": "#/$defs/freeze" },
        "autoFilter":         { "$ref": "#/$defs/autoFilter" },
        "tables":             { "$ref": "#/$defs/tables" },
        "sparklines":         { "$ref": "#/$defs/sparklines" },
        "conditionalFormats": { "$ref": "#/$defs/conditionalFormats" },
        "pictures":           { "$ref": "#/$defs/pictures" },
        "background":         { "$ref": "#/$defs/background" },
        "styles":             { "$ref": "#/$defs/styles" }
      },
      "required": ["cells"],
      "additionalProperties": false
    },

    "multiSheet": {
      "type": "object",
      "properties": {
        "sheets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":    { "$ref": "#/$defs/sheetName" },
              "cells":   { "$ref": "#/$defs/cells" },
              "rows":    { "$ref": "#/$defs/rows" },
              "cols":    { "$ref": "#/$defs/cols" },
              "rowDims": { "$ref": "#/$defs/rowDims" },
              "merges":             { "$ref": "#/$defs/merges" },
              "freeze":             { "$ref": "#/$defs/freeze" },
              "autoFilter":         { "$ref": "#/$defs/autoFilter" },
              "tables":             { "$ref": "#/$defs/tables" },
              "sparklines":         { "$ref": "#/$defs/sparklines" },
              "conditionalFormats": { "$ref": "#/$defs/conditionalFormats" },
              "pictures":           { "$ref": "#/$defs/pictures" },
              "background":         { "$ref": "#/$defs/background" }
            },
            "required": ["cells"],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "styles": { "$ref": "#/$defs/styles" }
      },
      "required": ["sheets"],
      "additionalProperties": false
    },

    "sheetName": {
      "type": "string",
      "description": "シート名"
    },

    "cells": {
      "type": "object",
      "description": "キーは A1 形式のセル参照",
      "patternProperties": {
        "^[A-Z]+[1-9][0-9]*$": { "$ref": "#/$defs/cell" }
      },
      "additionalProperties": false
    },

    "cell": {
      "type": "object",
      "description": "セルオブジェクト",
      "properties": {
        "t": { "$ref": "#/$defs/cellType" },
        "v": {},
        "f": { "type": "string", "description": "数式本体（= を含まない）" },
        "z": { "type": "string", "description": "数値書式コード" },
        "s": { "$ref": "#/$defs/styleRef" },
        "l": { "$ref": "#/$defs/hyperlink" }
      },
      "required": ["t"],
      "additionalProperties": false
    },

    "cellType": {
      "type": "string",
      "enum": ["s", "n", "b", "f", "d"],
      "description": "s=文字列, n=数値, b=真偽, f=数式, d=日付"
    },

    "styleRef": {
      "type": "integer",
      "description": "styles[].id への参照"
    },

    "hyperlink": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "target":  { "type": "string" },
            "tooltip": { "type": "string" }
          },
          "required": ["target"],
          "additionalProperties": false
        }
      ]
    },

    "rows": {
      "type": "array",
      "description": "行データ配列（拡張用）",
      "items": {}
    },

    "cols": {
      "type": "array",
      "description": "列幅設定",
      "items": { "$ref": "#/$defs/col" }
    },

    "col": {
      "type": "object",
      "properties": {
        "col":   { "type": "string", "description": "列記号 (A, B, ...)" },
        "width": { "type": "number", "description": "列幅" }
      },
      "required": ["col", "width"],
      "additionalProperties": false
    },

    "rowDims": {
      "type": "array",
      "description": "行高設定",
      "items": { "$ref": "#/$defs/rowDim" }
    },

    "rowDim": {
      "type": "object",
      "properties": {
        "row":    { "type": "integer", "description": "行番号 (1始まり)" },
        "height": { "type": "number",  "description": "行高" }
      },
      "required": ["row", "height"],
      "additionalProperties": false
    },

    "merges": {
      "type": "array",
      "description": "セル結合設定",
      "items": { "$ref": "#/$defs/merge" }
    },

    "merge": {
      "type": "object",
      "properties": {
        "range": { "type": "string", "description": "結合範囲 (例: A1:B1)" }
      },
      "required": ["range"],
      "additionalProperties": false
    },

    "freeze": {
      "type": "object",
      "description": "固定ペイン設定",
      "properties": {
        "row": { "type": "integer", "minimum": 1, "description": "固定する行数" },
        "col": { "type": "integer", "minimum": 1, "description": "固定する列数" }
      },
      "additionalProperties": false
    },

    "styles": {
      "type": "array",
      "description": "スタイル定義一覧",
      "items": { "$ref": "#/$defs/style" }
    },

    "style": {
      "type": "object",
      "description": "スタイル定義",
      "properties": {
        "id":        { "type": "integer" },
        "fill":      { "$ref": "#/$defs/fill" },
        "border":    { "$ref": "#/$defs/border" },
        "font":      { "$ref": "#/$defs/font" },
        "alignment": { "$ref": "#/$defs/alignment" },
        "numFmt":    { "type": "string", "description": "数値書式コード" }
      },
      "required": ["id"],
      "additionalProperties": false
    },

    "fill": {
      "type": "object",
      "description": "塗りつぶし設定",
      "properties": {
        "type":    { "type": "string", "enum": ["pattern"], "default": "pattern" },
        "pattern": { "type": "integer", "default": 1 },
        "color": {
          "type": "array",
          "description": "色の配列（#RRGGBB 形式）",
          "items": { "$ref": "#/$defs/colorValue" },
          "minItems": 1
        }
      },
      "required": ["type", "pattern", "color"],
      "additionalProperties": false
    },

    "border": {
      "type": "array",
      "description": "罫線設定",
      "items": { "$ref": "#/$defs/borderItem" }
    },

    "borderItem": {
      "type": "object",
      "properties": {
        "side": {
          "type": "string",
          "enum": ["left", "right", "top", "bottom"],
          "description": "省略時は四辺すべてに適用"
        },
        "style": {
          "type": "string",
          "enum": ["thin", "medium", "thick", "dashed", "dotted", "double", "hair", "mediumDashed", "dashDot", "mediumDashDot", "dashDotDot", "mediumDashDotDot", "slantDashDot"]
        },
        "color": { "$ref": "#/$defs/colorValue" }
      },
      "required": ["style", "color"],
      "additionalProperties": false
    },
    "font": {
      "type": "object",
      "description": "フォント設定",
      "properties": {
        "name":   { "type": "string", "default": "Calibri" },
        "size":   { "type": "number", "default": 11 },
        "bold":   { "type": "boolean" },
        "italic": { "type": "boolean" },
        "color":  { "$ref": "#/$defs/colorValue" }
      },
      "additionalProperties": false
    },

    "alignment": {
      "type": "object",
      "description": "セル配置設定",
      "properties": {
        "horizontal": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "vertical": {
          "type": "string",
          "enum": ["top", "center", "bottom"]
        },
        "wrapText": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "bookWrapped": {
      "type": "object",
      "description": "book ラッパー形式（version + book 配下に sheets/charts/props を持つ）",
      "properties": {
        "version": { "type": "string", "description": "スキーマバージョン（例: 0.1）" },
        "book": {
          "type": "object",
          "properties": {
            "props":  { "type": "object", "description": "文書プロパティ（任意）" },
            "sheets": {
              "type": "object",
              "description": "キーがシート名のオブジェクト",
              "additionalProperties": { "$ref": "#/$defs/bookSheet" }
            },
            "charts": {
              "type": "array",
              "description": "グラフオブジェクトの配列",
              "items": { "$ref": "#/$defs/chart" }
            },
            "styles": { "$ref": "#/$defs/styles" }
          },
          "required": ["sheets"],
          "additionalProperties": false
        }
      },
      "required": ["book"],
      "additionalProperties": false
    },

    "bookSheet": {
      "type": "object",
      "description": "book 内のシートオブジェクト（キーがシート名のため name フィールド不要）",
      "properties": {
        "cells":   { "$ref": "#/$defs/cells" },
        "rows":    { "$ref": "#/$defs/rows" },
        "cols":    { "$ref": "#/$defs/cols" },
        "rowDims": { "$ref": "#/$defs/rowDims" },
        "merges":             { "$ref": "#/$defs/merges" },
        "freeze":             { "$ref": "#/$defs/freeze" },
        "autoFilter":         { "$ref": "#/$defs/autoFilter" },
        "tables":             { "$ref": "#/$defs/tables" },
        "sparklines":         { "$ref": "#/$defs/sparklines" },
        "conditionalFormats": { "$ref": "#/$defs/conditionalFormats" },
        "pictures":           { "$ref": "#/$defs/pictures" },
        "background":         { "$ref": "#/$defs/background" }
      },
      "required": ["cells"],
      "additionalProperties": false
    },

    "chart": {
      "type": "object",
      "description": "グラフオブジェクト",
      "properties": {
        "id":     { "type": "string", "description": "一意な識別子（任意）" },
        "t":      { "type": "string", "description": "オブジェクト種別（chart 推奨）" },
        "mode":   { "type": "string", "enum": ["embedded", "chartSheet"], "default": "embedded", "description": "配置モード: embedded(通常シート埋め込み), chartSheet(グラフ専用シート)" },
        "ct":     { "type": "string", "description": "グラフ種別 (col, line, pie ...)" },
        "sheet":  { "type": "string", "description": "配置先シート名" },
        "anchor": { "type": "string", "description": "左上セルアドレス (A1 形式)。chartSheet モードでは無視" },
        "dim":    { "$ref": "#/$defs/chartDim" },
        "title":  { "$ref": "#/$defs/chartTitle" },
        "legend": { "$ref": "#/$defs/chartLegend" },
        "plot":   { "$ref": "#/$defs/chartPlot" },
        "xAxis":  { "$ref": "#/$defs/chartAxis" },
        "yAxis":  { "$ref": "#/$defs/chartAxis" },
        "ser":    {
          "type": "array",
          "items": { "$ref": "#/$defs/chartSeries" },
          "minItems": 1
        },
        "style": { "type": "object" },
        "meta":  { "type": "object" }
      },
      "required": ["ct", "sheet", "ser"],
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "chartSheet" } },
            "required": ["mode"]
          },
          "then": {
            "properties": { "anchor": { "description": "chartSheet モードでは anchor は無視される" } }
          },
          "else": {
            "required": ["anchor"]
          }
        }
      ],
      "additionalProperties": false
    },

    "chartDim": {
      "type": "object",
      "description": "グラフ領域のサイズ・オフセット",
      "properties": {
        "w":    { "type": "number" },
        "h":    { "type": "number" },
        "offx": { "type": "number" },
        "offy": { "type": "number" },
        "sx":   { "type": "number" },
        "sy":   { "type": "number" }
      },
      "additionalProperties": false
    },

    "chartTitle": {
      "type": "object",
      "description": "グラフタイトル",
      "properties": {
        "tx":      { "type": "string" },
        "overlay": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "chartLegend": {
      "type": "object",
      "description": "凡例設定",
      "properties": {
        "show": { "type": "boolean" },
        "pos":  { "type": "string", "enum": ["right", "left", "top", "bottom", "topRight"] }
      },
      "additionalProperties": false
    },

    "chartPlot": {
      "type": "object",
      "description": "プロット領域オプション",
      "properties": {
        "varyColors":   { "type": "boolean" },
        "showBlanksAs": { "type": "string", "enum": ["gap", "zero", "span"] }
      },
      "additionalProperties": false
    },

    "chartAxis": {
      "type": "object",
      "description": "軸設定",
      "properties": {
        "title":          { "type": "string" },
        "minimum":        { "type": ["number", "null"] },
        "maximum":        { "type": ["number", "null"] },
        "majorUnit":      { "type": ["number", "null"] },
        "minorUnit":      { "type": ["number", "null"] },
        "reverseOrder":   { "type": "boolean" },
        "majorGridLines": { "type": "boolean" },
        "minorGridLines": { "type": "boolean" },
        "numFmt":         { "type": "string" }
      },
      "additionalProperties": false
    },

    "chartSeries": {
      "type": "object",
      "description": "データ系列",
      "properties": {
        "name":   { "type": "string" },
        "cat":    { "type": "string" },
        "val":    { "type": "string" },
        "xVal":   { "type": ["string", "null"] },
        "yVal":   { "type": ["string", "null"] },
        "bubble": { "type": ["string", "null"] },
        "line":   { "$ref": "#/$defs/chartLine" },
        "fill":   { "$ref": "#/$defs/chartFill" },
        "marker": { "$ref": "#/$defs/chartMarker" },
        "dLbls":  { "$ref": "#/$defs/chartDLbls" }
      },
      "additionalProperties": false
    },

    "chartLine": {
      "type": "object",
      "description": "系列の線スタイル",
      "properties": {
        "color": { "$ref": "#/$defs/colorValue" },
        "width": { "type": "number" },
        "dash":  { "type": "string" }
      },
      "additionalProperties": false
    },

    "chartFill": {
      "type": "object",
      "description": "系列の塗りつぶし",
      "properties": {
        "color": { "$ref": "#/$defs/colorValue" }
      },
      "additionalProperties": false
    },

    "chartMarker": {
      "type": "object",
      "description": "系列のマーカー設定",
      "properties": {
        "symbol": { "type": "string" },
        "size":   { "type": "number" }
      },
      "additionalProperties": false
    },

    "chartDLbls": {
      "type": "object",
      "description": "データラベル設定",
      "properties": {
        "showVal":       { "type": "boolean" },
        "showCatName":   { "type": "boolean" },
        "showSerName":   { "type": "boolean" },
        "showPercent":   { "type": "boolean" },
        "showLeaderLn":  { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "sparklines": {
      "type": "array",
      "description": "スパークライン一覧",
      "items": { "$ref": "#/$defs/sparkline" }
    },

    "sparkline": {
      "type": "object",
      "description": "スパークライン",
      "properties": {
        "location":       { "type": "string", "description": "配置先セル (例: A2)" },
        "range":          { "type": "string", "description": "データ範囲 (例: Sheet1!B2:E2)" },
        "type":           { "type": "string", "enum": ["line", "column", "win_loss"], "description": "スパークライン種別" },
        "weight":         { "type": "number", "description": "線の太さ" },
        "dateAxis":       { "type": "boolean", "description": "日付軸を使用" },
        "markers":        { "type": "boolean", "description": "マーカー表示" },
        "high":           { "type": "boolean", "description": "最大値強調" },
        "low":            { "type": "boolean", "description": "最小値強調" },
        "first":          { "type": "boolean", "description": "最初の値強調" },
        "last":           { "type": "boolean", "description": "最後の値強調" },
        "negative":       { "type": "boolean", "description": "負の値強調" },
        "axis":           { "type": "boolean", "description": "軸表示" },
        "hidden":         { "type": "boolean", "description": "非表示の行/列のデータを表示" },
        "reverse":        { "type": "boolean", "description": "プロット方向を反転" },
        "style":          { "type": "integer", "minimum": 0, "maximum": 35, "description": "組み込みスタイル (0-35)" },
        "seriesColor":    { "$ref": "#/$defs/colorValue", "description": "線/棒の色" },
        "negativeColor":  { "$ref": "#/$defs/colorValue", "description": "負の値の色" },
        "markersColor":   { "$ref": "#/$defs/colorValue", "description": "マーカーの色" },
        "firstColor":     { "$ref": "#/$defs/colorValue", "description": "最初の値の色" },
        "lastColor":      { "$ref": "#/$defs/colorValue", "description": "最後の値の色" },
        "highColor":      { "$ref": "#/$defs/colorValue", "description": "最大値の色" },
        "lowColor":       { "$ref": "#/$defs/colorValue", "description": "最小値の色" },
        "emptyCells":     { "type": "string", "enum": ["zero", "gap", "span"], "description": "空セルの扱い" },
        "max":            { "type": "integer", "description": "軸の最大値のカスタマイズ方法" },
        "customMax":      { "type": "integer", "description": "軸の最大値" },
        "min":            { "type": "integer", "description": "軸の最小値のカスタマイズ方法" },
        "customMin":      { "type": "integer", "description": "軸の最小値" }
      },
      "required": ["location", "range"],
      "additionalProperties": false
    },

    "autoFilter": {
      "oneOf": [
        { "type": "string", "description": "範囲文字列 (例: A1:C10)" },
        {
          "type": "object",
          "description": "SheetJS 互換オブジェクト形式",
          "properties": {
            "ref": { "type": "string", "description": "範囲 (例: A1:C10)" }
          },
          "required": ["ref"],
          "additionalProperties": false
        }
      ]
    },

    "tables": {
      "type": "array",
      "description": "構造化テーブル一覧",
      "items": { "$ref": "#/$defs/table" }
    },

    "table": {
      "type": "object",
      "description": "構造化テーブル",
      "properties": {
        "range":         { "type": "string", "description": "テーブル範囲 (例: A1:C10)" },
        "name":          { "type": "string", "description": "テーブル名（省略時は自動生成）" },
        "style":         { "type": "string", "description": "テーブルスタイル名 (TableStyleMedium2 など)" },
        "bandedRows":    { "type": "boolean", "description": "交互行バンド" },
        "bandedColumns": { "type": "boolean", "description": "交互列バンド" },
        "firstColumn":   { "type": "boolean", "description": "先頭列強調" },
        "lastColumn":    { "type": "boolean", "description": "最終列強調" },
        "headerRow":     { "type": "boolean", "description": "ヘッダ行表示" }
      },
      "required": ["range"],
      "additionalProperties": false
    },

    "conditionalFormats": {
      "type": "array",
      "description": "条件付き書式設定の配列",
      "items": { "$ref": "#/$defs/conditionalFormat" }
    },

    "conditionalFormat": {
      "type": "object",
      "description": "条件付き書式グループ（範囲＋ルール群）",
      "properties": {
        "range": { "type": "string", "description": "適用範囲 (例: A1:A10)" },
        "rules": {
          "type": "array",
          "description": "ルールの配列",
          "items": { "$ref": "#/$defs/conditionalRule" },
          "minItems": 1
        }
      },
      "required": ["range", "rules"],
      "additionalProperties": false
    },

    "conditionalRule": {
      "type": "object",
      "description": "条件付き書式ルール",
      "properties": {
        "type": {
          "type": "string",
          "description": "ルール種別",
          "enum": ["cell", "formula", "2_color_scale", "3_color_scale", "data_bar", "iconSet", "top", "bottom", "average", "duplicate", "unique", "blanks", "no_blanks", "errors", "no_errors", "text", "time_period"]
        },
        "criteria":     { "type": "string", "description": "評価基準（>, <, between, ==, containsText など）" },
        "value":        { "type": "string", "description": "基準値" },
        "minValue":     { "type": "string", "description": "下限値" },
        "midValue":     { "type": "string", "description": "中間値（3_color_scale 用）" },
        "maxValue":     { "type": "string", "description": "上限値" },
        "style":        { "$ref": "#/$defs/conditionalStyle", "description": "条件成立時の書式" },
        "minType":      { "type": "string", "enum": ["min", "num", "percent", "percentile", "formula", "max"], "description": "最小値の種類" },
        "midType":      { "type": "string", "enum": ["num", "percent", "percentile", "formula"], "description": "中間値の種類" },
        "maxType":      { "type": "string", "enum": ["num", "percent", "percentile", "formula", "max"], "description": "最大値の種類" },
        "minColor":     { "$ref": "#/$defs/colorValue", "description": "色スケールの最小色" },
        "midColor":     { "$ref": "#/$defs/colorValue", "description": "色スケールの中間色" },
        "maxColor":     { "$ref": "#/$defs/colorValue", "description": "色スケールの最大色" },
        "barColor":     { "$ref": "#/$defs/colorValue", "description": "データバーの色" },
        "barBorderColor": { "$ref": "#/$defs/colorValue", "description": "データバーの枠線色" },
        "barDirection": { "type": "string", "enum": ["context", "leftToRight", "rightToLeft"], "description": "データバーの方向" },
        "barOnly":      { "type": "boolean", "description": "値非表示でバーのみ表示" },
        "barSolid":     { "type": "boolean", "description": "ベタ塗りデータバー" },
        "iconStyle":    { "type": "string", "description": "アイコンセット名 (3Arrows, 3TrafficLights1 など)" },
        "reverseIcons": { "type": "boolean", "description": "アイコン順序反転" },
        "iconsOnly":    { "type": "boolean", "description": "値非表示でアイコンのみ表示" },
        "aboveAverage": { "type": "boolean", "description": "平均以上（true）/ 平均以下（false）" },
        "percent":      { "type": "boolean", "description": "上位/下位 N% 指定" },
        "stopIfTrue":   { "type": "boolean", "description": "条件成立時に後続ルールを評価しない" }
      },
      "required": ["type"],
      "additionalProperties": false
    },

    "conditionalStyle": {
      "type": "object",
      "description": "条件付き書式用のインラインスタイル（dxf）",
      "properties": {
        "id":        { "type": "integer", "description": "省略可（インラインスタイルのため未使用）" },
        "fill":      { "$ref": "#/$defs/fill" },
        "border":    { "$ref": "#/$defs/border" },
        "font":      { "$ref": "#/$defs/font" },
        "alignment": { "$ref": "#/$defs/alignment" },
        "numFmt":    { "type": "string", "description": "数値書式コード" }
      },
      "additionalProperties": false
    },

    "pictures": {
      "type": "array",
      "description": "画像一覧",
      "items": { "$ref": "#/$defs/picture" }
    },

    "picture": {
      "type": "object",
      "description": "ワークシートに配置する画像",
      "properties": {
        "cell":            { "type": "string", "description": "配置先セル (例: C2)" },
        "path":            { "type": "string", "description": "画像ファイルのパス" },
        "data":            { "type": "string", "description": "base64 エンコードされた画像データ" },
        "extension":       { "type": "string", "description": "画像拡張子 (png, jpg, gif など)" },
        "altText":         { "type": "string", "description": "代替テキスト" },
        "printObject":     { "type": "boolean", "description": "印刷対象とする" },
        "locked":          { "type": "boolean", "description": "ロック" },
        "lockAspectRatio": { "type": "boolean", "description": "縦横比を固定" },
        "offsetX":         { "type": "integer", "description": "セル左上からの X オフセット（EMU）" },
        "offsetY":         { "type": "integer", "description": "セル左上からの Y オフセット（EMU）" },
        "scaleX":          { "type": "number", "description": "横幅の倍率 (1.0=100%)" },
        "scaleY":          { "type": "number", "description": "縦幅の倍率 (1.0=100%)" },
        "hyperlink":       { "type": "string", "description": "画像に設定するハイパーリンク" },
        "positioning":     { "type": "string", "enum": ["twoCell", "oneCell", "absolute"], "description": "配置動作 (twoCell=セルと移動/サイズ変更, oneCell=移動のみ, absolute=固定)" }
      },
      "required": ["cell"],
      "additionalProperties": false
    },

    "background": {
      "type": "object",
      "description": "シート背景画像",
      "properties": {
        "path":      { "type": "string", "description": "画像ファイルのパス" },
        "data":      { "type": "string", "description": "base64 エンコードされた画像データ" },
        "extension": { "type": "string", "description": "画像拡張子 (png, jpg, gif など)" }
      },
      "additionalProperties": false
    }
  }
}
