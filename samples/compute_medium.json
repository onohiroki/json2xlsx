{
  "name": "ComputeMediumSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 中優先度関数サンプル"},

    "A3": {"t": "s", "v": "--- FLOOR / CEILING / MOD / POWER / SQRT / INT ---"},
    "B3": {"t": "f", "f": "FLOOR(3.7,2)"},
    "C3": {"t": "f", "f": "FLOOR(-5.4,1)"},
    "D3": {"t": "f", "f": "CEILING(3.7,2)"},
    "E3": {"t": "f", "f": "CEILING(-2.5,2)"},
    "F3": {"t": "f", "f": "MOD(10,3)"},
    "G3": {"t": "f", "f": "MOD(-3,2)"},
    "H3": {"t": "f", "f": "POWER(2,3)"},
    "I3": {"t": "f", "f": "POWER(9,0.5)"},
    "J3": {"t": "f", "f": "SQRT(9)"},
    "K3": {"t": "f", "f": "INT(3.7)"},
    "L3": {"t": "f", "f": "INT(-5.4)"},

    "A5": {"t": "s", "v": "--- COUNTA ---"},
    "B5": {"t": "n", "v": 10},
    "C5": {"t": "s", "v": "hello"},
    "E5": {"t": "n", "v": 30},
    "F5": {"t": "f", "f": "COUNTA(B5:E5)"},
    "G5": {"t": "f", "f": "COUNTA(B5,C5)"},
    "H5": {"t": "f", "f": "COUNTA(99)"},

    "A7": {"t": "s", "v": "--- VAR / VAR.S / VAR.P ---"},
    "B7": {"t": "n", "v": 2},
    "C7": {"t": "n", "v": 4},
    "D7": {"t": "n", "v": 4},
    "E7": {"t": "n", "v": 4},
    "F7": {"t": "n", "v": 5},
    "G7": {"t": "n", "v": 5},
    "H7": {"t": "n", "v": 7},
    "I7": {"t": "n", "v": 9},
    "J7": {"t": "s", "v": "VAR.S(標本)"},
    "K7": {"t": "f", "f": "VAR.S(B7:I7)"},
    "L7": {"t": "s", "v": "VAR(同)"},
    "M7": {"t": "f", "f": "VAR(B7:I7)"},
    "N7": {"t": "s", "v": "VAR.P(母)"},
    "O7": {"t": "f", "f": "VAR.P(B7:I7)"},

    "A9": {"t": "s", "v": "--- RANK / RANK.EQ ---"},
    "B9": {"t": "n", "v": 10},
    "C9": {"t": "n", "v": 20},
    "D9": {"t": "n", "v": 30},
    "E9": {"t": "f", "f": "RANK(30,B9:D9)"},
    "F9": {"t": "f", "f": "RANK(20,B9:D9)"},
    "G9": {"t": "f", "f": "RANK(10,B9:D9,1)"},
    "H9": {"t": "f", "f": "RANK.EQ(30,B9:D9)"},

    "A11": {"t": "s", "v": "--- LARGE / SMALL ---"},
    "B11": {"t": "n", "v": 5},
    "C11": {"t": "n", "v": 3},
    "D11": {"t": "n", "v": 7},
    "E11": {"t": "n", "v": 1},
    "F11": {"t": "n", "v": 9},
    "G11": {"t": "f", "f": "LARGE(B11:F11,1)"},
    "H11": {"t": "f", "f": "LARGE(B11:F11,3)"},
    "I11": {"t": "f", "f": "SMALL(B11:F11,1)"},
    "J11": {"t": "f", "f": "SMALL(B11:F11,3)"},

    "A13": {"t": "s", "v": "--- TODAY / NOW ---"},
    "B13": {"t": "f", "f": "TODAY()"},
    "C13": {"t": "f", "f": "NOW()"},

    "A15": {"t": "s", "v": "--- AVERAGEIF ---"},
    "B15": {"t": "n", "v": 10},
    "C15": {"t": "n", "v": 20},
    "D15": {"t": "n", "v": 10},
    "E15": {"t": "n", "v": 100},
    "F15": {"t": "n", "v": 200},
    "G15": {"t": "n", "v": 300},
    "H15": {"t": "f", "f": "AVERAGEIF(B15:D15,10,E15:G15)"},

    "A17": {"t": "s", "v": "--- SUMIFS / COUNTIFS / AVERAGEIFS ---"},
    "B17": {"t": "n", "v": 100},
    "C17": {"t": "n", "v": 200},
    "D17": {"t": "n", "v": 300},
    "E17": {"t": "n", "v": 10},
    "F17": {"t": "n", "v": 20},
    "G17": {"t": "n", "v": 10},
    "H17": {"t": "n", "v": 1},
    "I17": {"t": "n", "v": 1},
    "J17": {"t": "n", "v": 2},
    "K17": {"t": "f", "f": "SUMIFS(B17:D17,E17:G17,10)"},
    "L17": {"t": "f", "f": "COUNTIFS(E17:G17,10)"},
    "M17": {"t": "f", "f": "AVERAGEIFS(B17:D17,E17:G17,10)"},

    "A19": {"t": "s", "v": "--- IFERROR ---"},
    "B19": {"t": "f", "f": "IFERROR(100,999)"},
    "C19": {"t": "f", "f": "IFERROR(1/0,999)"},
    "D19": {"t": "f", "f": "IFERROR(SQRT(9),-1)"}
  }
}
