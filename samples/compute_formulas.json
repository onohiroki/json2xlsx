{
  "name": "ComputeSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 動作確認用サンプル"},
    "A3": {"t": "s", "v": "--- 四則演算 ---"},
    "A4": {"t": "s", "v": "加算"},
    "B4": {"t": "n", "v": 10},
    "C4": {"t": "n", "v": 20},
    "D4": {"t": "f", "f": "B4+C4"},
    "A5": {"t": "s", "v": "減算"},
    "B5": {"t": "n", "v": 100},
    "C5": {"t": "n", "v": 30},
    "D5": {"t": "f", "f": "B5-C5"},
    "A6": {"t": "s", "v": "乗算"},
    "B6": {"t": "n", "v": 6},
    "C6": {"t": "n", "v": 7},
    "D6": {"t": "f", "f": "B6*C6"},
    "A7": {"t": "s", "v": "除算"},
    "B7": {"t": "n", "v": 50},
    "C7": {"t": "n", "v": 8},
    "D7": {"t": "f", "f": "B7/C7"},
    "A8": {"t": "s", "v": "複合（括弧）"},
    "B8": {"t": "n", "v": 2},
    "C8": {"t": "n", "v": 3},
    "D8": {"t": "n", "v": 4},
    "E8": {"t": "f", "f": "(B8+C8)*D8"},
    "A9": {"t": "s", "v": "単項マイナス"},
    "B9": {"t": "n", "v": 10},
    "C9": {"t": "f", "f": "-B9"},
    "D9": {"t": "f", "f": "B9+-B9"},

    "A11": {"t": "s", "v": "--- SUM ---"},
    "A12": {"t": "s", "v": "範囲合計"},
    "B12": {"t": "n", "v": 1},
    "C12": {"t": "n", "v": 2},
    "D12": {"t": "n", "v": 3},
    "E12": {"t": "n", "v": 4},
    "F12": {"t": "f", "f": "SUM(B12:E12)"},
    "A13": {"t": "s", "v": "複数範囲"},
    "B13": {"t": "n", "v": 10},
    "C13": {"t": "n", "v": 20},
    "D13": {"t": "n", "v": 100},
    "E13": {"t": "f", "f": "SUM(B13:C13,D13)"},
    "A14": {"t": "s", "v": "逆順範囲"},
    "B14": {"t": "n", "v": 5},
    "C14": {"t": "n", "v": 10},
    "D14": {"t": "n", "v": 15},
    "E14": {"t": "f", "f": "SUM(D14:B14)"},

    "A16": {"t": "s", "v": "--- AVERAGE ---"},
    "A17": {"t": "s", "v": "平均"},
    "B17": {"t": "n", "v": 10},
    "C17": {"t": "n", "v": 20},
    "D17": {"t": "n", "v": 30},
    "E17": {"t": "n", "v": 40},
    "F17": {"t": "f", "f": "AVERAGE(B17:E17)"},

    "A19": {"t": "s", "v": "--- MIN / MAX ---"},
    "A20": {"t": "s", "v": "データ"},
    "B20": {"t": "n", "v": 8},
    "C20": {"t": "n", "v": 3},
    "D20": {"t": "n", "v": 15},
    "E20": {"t": "n", "v": 1},
    "F20": {"t": "n", "v": 9},
    "A21": {"t": "s", "v": "最小"},
    "F21": {"t": "f", "f": "MIN(B20:F20)"},
    "A22": {"t": "s", "v": "最大"},
    "F22": {"t": "f", "f": "MAX(B20:F20)"},

    "A24": {"t": "s", "v": "--- COUNT ---"},
    "A25": {"t": "s", "v": "データ"},
    "B25": {"t": "n", "v": 10},
    "C25": {"t": "n", "v": 20},
    "D25": {"t": "s", "v": "文字列"},
    "E25": {"t": "n", "v": 30},
    "A26": {"t": "s", "v": "数値セル数"},
    "F26": {"t": "f", "f": "COUNT(B25:E25)"},

    "A28": {"t": "s", "v": "--- ABS ---"},
    "B28": {"t": "n", "v": -7},
    "C28": {"t": "f", "f": "ABS(B28)"},
    "D28": {"t": "f", "f": "ABS(0)"},

    "A30": {"t": "s", "v": "--- ROUND ---"},
    "B30": {"t": "n", "v": 3.141592},
    "C30": {"t": "f", "f": "ROUND(B30,2)"},
    "D30": {"t": "f", "f": "ROUND(B30,0)"},
    "E30": {"t": "f", "f": "ROUND(B30,4)"},

    "A32": {"t": "s", "v": "--- 絶対参照・混合参照 ---"},
    "B32": {"t": "n", "v": 5},
    "C32": {"t": "s", "v": "$B$32 参照"},
    "D32": {"t": "f", "f": "$B$32*2"},
    "C33": {"t": "s", "v": "$B32 参照"},
    "D33": {"t": "f", "f": "$B32+3"},
    "C34": {"t": "s", "v": "B$32 参照"},
    "D34": {"t": "f", "f": "B$32-1"},

    "A36": {"t": "s", "v": "--- チェーン計算 ---"},
    "B36": {"t": "n", "v": 2},
    "C36": {"t": "f", "f": "B36*3"},
    "D36": {"t": "f", "f": "C36+10"},
    "E36": {"t": "f", "f": "D36/2"},

    "A38": {"t": "s", "v": "--- 関数の組み合わせ ---"},
    "B38": {"t": "n", "v": 1},
    "C38": {"t": "n", "v": 2},
    "D38": {"t": "n", "v": 3},
    "E38": {"t": "n", "v": 4},
    "F38": {"t": "f", "f": "SUM(B38:E38)*AVERAGE(B38:E38)"},

    "A40": {"t": "s", "v": "--- ゼロ除算（エラー通知） ---"},
    "B40": {"t": "n", "v": 10},
    "C40": {"t": "n", "v": 0},
    "D40": {"t": "f", "f": "B40/C40"},

    "A42": {"t": "s", "v": "--- 比較演算子 ---"},
    "A43": {"t": "s", "v": "等しい"},
    "B43": {"t": "n", "v": 10},
    "C43": {"t": "n", "v": 10},
    "D43": {"t": "f", "f": "B43=C43"},
    "A44": {"t": "s", "v": "等しくない"},
    "B44": {"t": "n", "v": 10},
    "C44": {"t": "n", "v": 20},
    "D44": {"t": "f", "f": "B44<>C44"},
    "A45": {"t": "s", "v": "より小さい"},
    "B45": {"t": "n", "v": 10},
    "C45": {"t": "n", "v": 20},
    "D45": {"t": "f", "f": "B45<C45"},
    "A46": {"t": "s", "v": "より大きい"},
    "B46": {"t": "n", "v": 20},
    "C46": {"t": "n", "v": 10},
    "D46": {"t": "f", "f": "B46>C46"},
    "A47": {"t": "s", "v": "以下"},
    "B47": {"t": "n", "v": 10},
    "C47": {"t": "n", "v": 10},
    "D47": {"t": "f", "f": "B47<=C47"},
    "A48": {"t": "s", "v": "以上"},
    "B48": {"t": "n", "v": 20},
    "C48": {"t": "n", "v": 10},
    "D48": {"t": "f", "f": "B48>=C48"},
    "A49": {"t": "s", "v": "算術と比較の優先順位"},
    "B49": {"t": "n", "v": 1},
    "C49": {"t": "n", "v": 2},
    "D49": {"t": "n", "v": 3},
    "E49": {"t": "n", "v": 4},
    "F49": {"t": "f", "f": "B49+C49<D49+E49"},
    "A50": {"t": "s", "v": "連鎖比較"},
    "B50": {"t": "f", "f": "1<2<3"},

    "A52": {"t": "s", "v": "--- IF ---"},
    "A53": {"t": "s", "v": "条件真"},
    "B53": {"t": "f", "f": "IF(1,100,200)"},
    "A54": {"t": "s", "v": "条件偽"},
    "B54": {"t": "f", "f": "IF(0,100,200)"},
    "A55": {"t": "s", "v": "比較とIF"},
    "B55": {"t": "n", "v": 15},
    "C55": {"t": "f", "f": "IF(B55>10,100,200)"},
    "A56": {"t": "s", "v": "ショートサーキット（0除算回避）"},
    "B56": {"t": "f", "f": "IF(0,1/0,999)"},
    "A57": {"t": "s", "v": "ネストIF"},
    "B57": {"t": "n", "v": 85},
    "C57": {"t": "f", "f": "IF(B57>=90,1,IF(B57>=80,2,3))"},

    "A59": {"t": "s", "v": "--- AND / OR / NOT ---"},
    "A60": {"t": "s", "v": "AND(1,1,1)"},
    "B60": {"t": "f", "f": "AND(1,1,1)"},
    "A61": {"t": "s", "v": "AND(1,0,1)"},
    "B61": {"t": "f", "f": "AND(1,0,1)"},
    "A62": {"t": "s", "v": "OR(0,0,1)"},
    "B62": {"t": "f", "f": "OR(0,0,1)"},
    "A63": {"t": "s", "v": "OR(0,0,0)"},
    "B63": {"t": "f", "f": "OR(0,0,0)"},
    "A64": {"t": "s", "v": "NOT(0)"},
    "B64": {"t": "f", "f": "NOT(0)"},
    "A65": {"t": "s", "v": "NOT(1)"},
    "B65": {"t": "f", "f": "NOT(1)"},

    "A67": {"t": "s", "v": "--- IF+論理関数の組み合わせ ---"},
    "A68": {"t": "s", "v": "IF+AND"},
    "B68": {"t": "n", "v": 15},
    "C68": {"t": "n", "v": 5},
    "D68": {"t": "f", "f": "IF(AND(B68>10,C68>0),100,200)"},
    "A69": {"t": "s", "v": "IF+OR"},
    "B69": {"t": "f", "f": "IF(OR(1=2,3=3),100,200)"},
    "A70": {"t": "s", "v": "IF+NOT"},
    "B70": {"t": "n", "v": 0},
    "C70": {"t": "f", "f": "IF(NOT(B70),100,200)"},

    "A72": {"t": "s", "v": "--- ショートサーキット検証 ---"},
    "A73": {"t": "s", "v": "AND 第2引数未評価"},
    "B73": {"t": "f", "f": "AND(0,1/0)"},
    "A74": {"t": "s", "v": "OR 第2引数未評価"},
    "B74": {"t": "f", "f": "OR(1,1/0)"},

    "A76": {"t": "s", "v": "--- 比較+既存関数 ---"},
    "A77": {"t": "s", "v": "SUM+IF"},
    "B77": {"t": "n", "v": 10},
    "C77": {"t": "n", "v": 20},
    "D77": {"t": "n", "v": 30},
    "E77": {"t": "f", "f": "IF(SUM(B77:D77)>50,1,0)"}
  }
}
