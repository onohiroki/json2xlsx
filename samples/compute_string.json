{
  "name": "StringFuncSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 文字列関数サンプル"},

    "A3": {"t": "s", "v": "--- 文字列リテラル / & 連結 / 比較 ---"},
    "A4": {"t": "f", "f": "\"Hello\" & \" \" & \"World\""},
    "A5": {"t": "f", "f": "IF(A6=\"合格\",\"合格です\",\"不合格です\")"},
    "B6": {"t": "s", "v": "合格"},

    "A8": {"t": "s", "v": "--- CONCAT / CONCATENATE ---"},
    "A9": {"t": "f", "f": "CONCAT(\"abc\",\"def\",\"ghi\")"},
    "A10": {"t": "f", "f": "CONCATENATE(\"x\",\"y\",\"z\")"},
    "A11": {"t": "n", "v": 100},
    "B11": {"t": "s", "v": "円"},
    "C11": {"t": "f", "f": "CONCAT(A11,B11)"},

    "A13": {"t": "s", "v": "--- LEFT / RIGHT / MID (rune 単位, 日本語対応) ---"},
    "A14": {"t": "f", "f": "LEFT(\"あいうえお\",3)"},
    "A15": {"t": "f", "f": "RIGHT(\"あいうえお\",2)"},
    "A16": {"t": "f", "f": "MID(\"あいうえお\",2,3)"},
    "A17": {"t": "f", "f": "LEFT(\"Hello\",2)"},

    "A19": {"t": "s", "v": "--- LEN (rune 単位) ---"},
    "A20": {"t": "f", "f": "LEN(\"あいうえお\")"},
    "A21": {"t": "f", "f": "LEN(\"Hello\")"},
    "A22": {"t": "f", "f": "LEN(\"\")"},

    "A24": {"t": "s", "v": "--- UPPER / LOWER ---"},
    "A25": {"t": "f", "f": "UPPER(\"hello\")"},
    "A26": {"t": "f", "f": "LOWER(\"HELLO\")"},

    "A28": {"t": "s", "v": "--- TRIM ---"},
    "A29": {"t": "f", "f": "TRIM(\"   Hello   World  \")"},

    "A31": {"t": "s", "v": "--- SUMIF / COUNTIF 文字列条件 ---"},
    "B32": {"t": "s", "v": "apple"},
    "C32": {"t": "n", "v": 100},
    "B33": {"t": "s", "v": "banana"},
    "C33": {"t": "n", "v": 200},
    "B34": {"t": "s", "v": "apple"},
    "C34": {"t": "n", "v": 300},
    "A35": {"t": "s", "v": "SUMIF(B32:B34,\"apple\",C32:C34)"},
    "B35": {"t": "f", "f": "SUMIF(B32:B34,\"apple\",C32:C34)"},
    "A36": {"t": "s", "v": "COUNTIF(B32:B34,\"apple\")"},
    "B36": {"t": "f", "f": "COUNTIF(B32:B34,\"apple\")"},

    "A38": {"t": "s", "v": "--- VLOOKUP 文字列キー ---"},
    "B39": {"t": "s", "v": "商品A"},
    "C39": {"t": "n", "v": 1000},
    "B40": {"t": "s", "v": "商品B"},
    "C40": {"t": "n", "v": 2000},
    "B41": {"t": "s", "v": "商品C"},
    "C41": {"t": "n", "v": 3000},
    "A42": {"t": "s", "v": "VLOOKUP(\"商品B\",B39:C41,2)"},
    "B42": {"t": "f", "f": "VLOOKUP(\"商品B\",B39:C41,2)"},

    "A44": {"t": "s", "v": "--- IFERROR 文字列 ---"},
    "A45": {"t": "f", "f": "IFERROR(1/0,\"エラー\")"},
    "A46": {"t": "f", "f": "IFERROR(\"正常\",999)"}
  }
}
