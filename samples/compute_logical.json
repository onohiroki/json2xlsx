{
  "name": "ComputeLogicalSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 論理関数サンプル"},

    "A3": {"t": "s", "v": "--- IF ---"},
    "A4": {"t": "s", "v": "条件真"},
    "B4": {"t": "f", "f": "IF(1,100,200)"},
    "A5": {"t": "s", "v": "条件偽"},
    "B5": {"t": "f", "f": "IF(0,100,200)"},
    "A6": {"t": "s", "v": "比較とIF"},
    "B6": {"t": "n", "v": 15},
    "C6": {"t": "f", "f": "IF(B6>10,100,200)"},
    "A7": {"t": "s", "v": "ショートサーキット（0除算回避）"},
    "B7": {"t": "f", "f": "IF(0,1/0,999)"},
    "A8": {"t": "s", "v": "ネストIF"},
    "B8": {"t": "n", "v": 85},
    "C8": {"t": "f", "f": "IF(B8>=90,1,IF(B8>=80,2,3))"},

    "A10": {"t": "s", "v": "--- AND / OR / NOT ---"},
    "A11": {"t": "s", "v": "AND(1,1,1)"},
    "B11": {"t": "f", "f": "AND(1,1,1)"},
    "A12": {"t": "s", "v": "AND(1,0,1)"},
    "B12": {"t": "f", "f": "AND(1,0,1)"},
    "A13": {"t": "s", "v": "OR(0,0,1)"},
    "B13": {"t": "f", "f": "OR(0,0,1)"},
    "A14": {"t": "s", "v": "OR(0,0,0)"},
    "B14": {"t": "f", "f": "OR(0,0,0)"},
    "A15": {"t": "s", "v": "NOT(0)"},
    "B15": {"t": "f", "f": "NOT(0)"},
    "A16": {"t": "s", "v": "NOT(1)"},
    "B16": {"t": "f", "f": "NOT(1)"},

    "A18": {"t": "s", "v": "--- IF+論理関数の組み合わせ ---"},
    "A19": {"t": "s", "v": "IF+AND"},
    "B19": {"t": "n", "v": 15},
    "C19": {"t": "n", "v": 5},
    "D19": {"t": "f", "f": "IF(AND(B19>10,C19>0),100,200)"},
    "A20": {"t": "s", "v": "IF+OR"},
    "B20": {"t": "f", "f": "IF(OR(1=2,3=3),100,200)"},
    "A21": {"t": "s", "v": "IF+NOT"},
    "B21": {"t": "n", "v": 0},
    "C21": {"t": "f", "f": "IF(NOT(B21),100,200)"},

    "A23": {"t": "s", "v": "--- ショートサーキット検証 ---"},
    "A24": {"t": "s", "v": "AND 第2引数未評価"},
    "B24": {"t": "f", "f": "AND(0,1/0)"},
    "A25": {"t": "s", "v": "OR 第2引数未評価"},
    "B25": {"t": "f", "f": "OR(1,1/0)"},

    "A27": {"t": "s", "v": "--- 比較+既存関数 ---"},
    "A28": {"t": "s", "v": "SUM+IF"},
    "B28": {"t": "n", "v": 10},
    "C28": {"t": "n", "v": 20},
    "D28": {"t": "n", "v": 30},
    "E28": {"t": "f", "f": "IF(SUM(B28:D28)>50,1,0)"}
  }
}
