{
  "name": "ComputeNewSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 新規実装関数サンプル"},

    "A3": {"t": "s", "v": "--- IFS / SWITCH ---"},
    "A4": {"t": "s", "v": "IFS"},
    "B4": {"t": "n", "v": 85},
    "C4": {"t": "f", "f": "IFS(B4>=90,1,B4>=80,2,B4>=70,3)"},
    "A5": {"t": "s", "v": "SWITCH"},
    "B5": {"t": "n", "v": 2},
    "C5": {"t": "f", "f": "SWITCH(B5,1,100,2,200,3,300,999)"},

    "A7": {"t": "s", "v": "--- YEAR / MONTH / DAY / WEEKDAY / WEEKNUM ---"},
    "B7": {"t": "n", "v": 45658},
    "A8": {"t": "s", "v": "YEAR(45658)"},
    "B8": {"t": "f", "f": "YEAR(B7)"},
    "A9": {"t": "s", "v": "MONTH(45658)"},
    "B9": {"t": "f", "f": "MONTH(B7)"},
    "A10": {"t": "s", "v": "DAY(45658)"},
    "B10": {"t": "f", "f": "DAY(B7)"},
    "A11": {"t": "s", "v": "WEEKDAY(45658)"},
    "B11": {"t": "f", "f": "WEEKDAY(B7)"},
    "A12": {"t": "s", "v": "WEEKNUM(45658)"},
    "B12": {"t": "f", "f": "WEEKNUM(B7)"},

    "A14": {"t": "s", "v": "--- DATE / EDATE / EOMONTH / DAYS / NETWORKDAYS / WORKDAY ---"},
    "A15": {"t": "s", "v": "DATE(2025,1,15)"},
    "B15": {"t": "f", "f": "DATE(2025,1,15)"},
    "A16": {"t": "s", "v": "EDATE(45658,3)"},
    "B16": {"t": "f", "f": "EDATE(B7,3)"},
    "A17": {"t": "s", "v": "EOMONTH(45658,0)"},
    "B17": {"t": "f", "f": "EOMONTH(B7,0)"},
    "A18": {"t": "s", "v": "DAYS(45658,45400)"},
    "B18": {"t": "f", "f": "DAYS(B7,45400)"},
    "A19": {"t": "s", "v": "NETWORKDAYS(45400,B7)"},
    "B19": {"t": "f", "f": "NETWORKDAYS(45400,B7)"},
    "A20": {"t": "s", "v": "WORKDAY(45400,5)"},
    "B20": {"t": "f", "f": "WORKDAY(45400,5)"},

    "A22": {"t": "s", "v": "--- MINIFS / MAXIFS ---"},
    "B22": {"t": "n", "v": 10},
    "C22": {"t": "n", "v": 1},
    "B23": {"t": "n", "v": 20},
    "C23": {"t": "n", "v": 1},
    "B24": {"t": "n", "v": 30},
    "C24": {"t": "n", "v": 2},
    "A25": {"t": "s", "v": "MINIFS(B22:B24,C22:C24,1)"},
    "B25": {"t": "f", "f": "MINIFS(B22:B24,C22:C24,1)"},
    "A26": {"t": "s", "v": "MAXIFS(B22:B24,C22:C24,1)"},
    "B26": {"t": "f", "f": "MAXIFS(B22:B24,C22:C24,1)"},

    "A28": {"t": "s", "v": "--- QUARTILE.INC / PERCENTILE.INC ---"},
    "A29": {"t": "n", "v": 1},
    "B29": {"t": "n", "v": 2},
    "C29": {"t": "n", "v": 3},
    "D29": {"t": "n", "v": 4},
    "E29": {"t": "n", "v": 5},
    "A30": {"t": "s", "v": "QUARTILE.INC(A29:E29,1)"},
    "B30": {"t": "f", "f": "QUARTILE.INC(A29:E29,1)"},
    "A31": {"t": "s", "v": "PERCENTILE.INC(A29:E29,0.5)"},
    "B31": {"t": "f", "f": "PERCENTILE.INC(A29:E29,0.5)"},
    "A32": {"t": "s", "v": "GEOMEAN(A29:E29)"},
    "B32": {"t": "f", "f": "GEOMEAN(A29:E29)"},
    "A33": {"t": "s", "v": "HARMEAN(A29:E29)"},
    "B33": {"t": "f", "f": "HARMEAN(A29:E29)"},
    "A34": {"t": "s", "v": "TRIMMEAN(A29:E29,0.2)"},
    "B34": {"t": "f", "f": "TRIMMEAN(A29:E29,0.2)"},

    "A36": {"t": "s", "v": "--- MODE / MODE.SNGL ---"},
    "A37": {"t": "n", "v": 1},
    "B37": {"t": "n", "v": 2},
    "C37": {"t": "n", "v": 2},
    "D37": {"t": "n", "v": 3},
    "A38": {"t": "s", "v": "MODE(A37:D37)"},
    "B38": {"t": "f", "f": "MODE(A37:D37)"},
    "A39": {"t": "s", "v": "MODE.SNGL(A37:D37)"},
    "B39": {"t": "f", "f": "MODE.SNGL(A37:D37)"},

    "A41": {"t": "s", "v": "--- SUMSQ / EVEN / ODD / MROUND / DELTA / GESTEP ---"},
    "A42": {"t": "s", "v": "SUMSQ(3,4)"},
    "B42": {"t": "f", "f": "SUMSQ(3,4)"},
    "A43": {"t": "s", "v": "EVEN(2.3)"},
    "B43": {"t": "f", "f": "EVEN(2.3)"},
    "A44": {"t": "s", "v": "ODD(2)"},
    "B44": {"t": "f", "f": "ODD(2)"},
    "A45": {"t": "s", "v": "MROUND(10,3)"},
    "B45": {"t": "f", "f": "MROUND(10,3)"},
    "A46": {"t": "s", "v": "DELTA(5,5)"},
    "B46": {"t": "f", "f": "DELTA(5,5)"},
    "A47": {"t": "s", "v": "GESTEP(5,4)"},
    "B47": {"t": "f", "f": "GESTEP(5,4)"},

    "A49": {"t": "s", "v": "--- HLOOKUP ---"},
    "A50": {"t": "n", "v": 1},
    "B50": {"t": "n", "v": 2},
    "C50": {"t": "n", "v": 3},
    "A51": {"t": "n", "v": 10},
    "B51": {"t": "n", "v": 20},
    "C51": {"t": "n", "v": 30},
    "A52": {"t": "s", "v": "HLOOKUP(2,A50:C51,2)"},
    "B52": {"t": "f", "f": "HLOOKUP(2,A50:C51,2)"},

    "A54": {"t": "s", "v": "--- ISNUMBER / ISBLANK / ISTEXT / ISNONTEXT / ISERROR / ISNA ---"},
    "A55": {"t": "n", "v": 42},
    "B55": {"t": "s", "v": "hello"},
    "C55": {"t": "f", "f": "1/0"},
    "A56": {"t": "s", "v": "ISNUMBER(A55)"},
    "B56": {"t": "f", "f": "ISNUMBER(A55)"},
    "A57": {"t": "s", "v": "ISBLANK(Z99)"},
    "B57": {"t": "f", "f": "ISBLANK(Z99)"},
    "A58": {"t": "s", "v": "ISTEXT(B55)"},
    "B58": {"t": "f", "f": "ISTEXT(B55)"},
    "A59": {"t": "s", "v": "ISNONTEXT(A55)"},
    "B59": {"t": "f", "f": "ISNONTEXT(A55)"},
    "A60": {"t": "s", "v": "ISERROR(1/0)"},
    "B60": {"t": "f", "f": "ISERROR(1/0)"},
    "A61": {"t": "s", "v": "ISNA(MODE(1,2,3))"},
    "B61": {"t": "f", "f": "ISNA(MODE(1,2,3))"},

    "A63": {"t": "s", "v": "--- SUBTOTAL ---"},
    "A64": {"t": "n", "v": 1},
    "B64": {"t": "n", "v": 2},
    "C64": {"t": "n", "v": 3},
    "D64": {"t": "n", "v": 4},
    "A65": {"t": "s", "v": "SUBTOTAL(1,A64:D64)"},
    "B65": {"t": "f", "f": "SUBTOTAL(1,A64:D64)"},
    "A66": {"t": "s", "v": "SUBTOTAL(9,A64:D64)"},
    "B66": {"t": "f", "f": "SUBTOTAL(9,A64:D64)"},

    "A68": {"t": "s", "v": "--- ROW / COLUMN ---"},
    "B68": {"t": "f", "f": "ROW()"},
    "C68": {"t": "f", "f": "COLUMN()"},
    "A69": {"t": "s", "v": "ROW(B5) => 5"},
    "B69": {"t": "f", "f": "ROW(B5)"},
    "A70": {"t": "s", "v": "COLUMN(C5) => 3"},
    "B70": {"t": "f", "f": "COLUMN(C5)"}
  }
}
