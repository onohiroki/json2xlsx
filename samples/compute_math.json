    "C37": {"t": "n", "v": 1},
    "D37": {"t": "n", "v": 2},
    "E37": {"t": "n", "v": 0.5},
    "A38": {"t": "s", "v": "ASINH"},
    "B38": {"t": "f", "f": "ASINH(B37)"},
