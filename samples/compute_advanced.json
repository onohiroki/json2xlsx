{
  "name": "ComputeAdvancedSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute advance sample"},

    "A3": {"t": "s", "v": "--- PRODUCT ---"},
    "A4": {"t": "s", "v": "数値直接"},
    "B4": {"t": "f", "f": "PRODUCT(2,3,4)"},
    "C4": {"t": "f", "f": "PRODUCT(10,0.5)"},
    "A5": {"t": "s", "v": "範囲参照"},
    "B5": {"t": "n", "v": 5},
    "C5": {"t": "n", "v": 6},
    "D5": {"t": "f", "f": "PRODUCT(B5:C5,2)"},

    "A7": {"t": "s", "v": "--- ROUNDUP ---"},
    "B7": {"t": "f", "f": "ROUNDUP(3.1415,2)"},
    "C7": {"t": "f", "f": "ROUNDUP(3.1415,0)"},
    "D7": {"t": "f", "f": "ROUNDUP(-3.1415,2)"},

    "A9": {"t": "s", "v": "--- ROUNDDOWN ---"},
    "B9": {"t": "f", "f": "ROUNDDOWN(3.1415,2)"},
    "C9": {"t": "f", "f": "ROUNDDOWN(3.1415,0)"},
    "D9": {"t": "f", "f": "ROUNDDOWN(-3.1415,2)"},

    "A11": {"t": "s", "v": "--- SUMPRODUCT ---"},
    "B11": {"t": "n", "v": 1},
    "C11": {"t": "n", "v": 2},
    "D11": {"t": "n", "v": 3},
    "E11": {"t": "n", "v": 10},
    "F11": {"t": "n", "v": 20},
    "G11": {"t": "n", "v": 30},
    "H11": {"t": "f", "f": "SUMPRODUCT(B11:D11,E11:G11)"},

    "A13": {"t": "s", "v": "--- MEDIAN ---"},
    "B13": {"t": "n", "v": 1},
    "C13": {"t": "n", "v": 3},
    "D13": {"t": "n", "v": 5},
    "E13": {"t": "f", "f": "MEDIAN(B13:D13)"},
    "F13": {"t": "f", "f": "MEDIAN(1,2,3,4)"},

    "A15": {"t": "s", "v": "--- STDEV.S / STDEV / STDEV.P ---"},
    "B15": {"t": "n", "v": 2},
    "C15": {"t": "n", "v": 4},
    "D15": {"t": "n", "v": 4},
    "E15": {"t": "n", "v": 4},
    "F15": {"t": "n", "v": 5},
    "G15": {"t": "n", "v": 5},
    "H15": {"t": "n", "v": 7},
    "I15": {"t": "n", "v": 9},
    "J15": {"t": "s", "v": "STDEV.S(標本)"},
    "K15": {"t": "f", "f": "STDEV.S(B15:I15)"},
    "L15": {"t": "s", "v": "STDEV(同上)"},
    "M15": {"t": "f", "f": "STDEV(B15:I15)"},
    "N15": {"t": "s", "v": "STDEV.P(母集団)"},
    "O15": {"t": "f", "f": "STDEV.P(B15:I15)"},

    "A17": {"t": "s", "v": "--- SUMIF ---"},
    "B17": {"t": "n", "v": 10},
    "C17": {"t": "n", "v": 20},
    "D17": {"t": "n", "v": 10},
    "E17": {"t": "n", "v": 30},
    "F17": {"t": "s", "v": "10を合計"},
    "G17": {"t": "f", "f": "SUMIF(B17:E17,10)"},

    "A18": {"t": "s", "v": "SUMIF + sum_range"},
    "B18": {"t": "n", "v": 10},
    "C18": {"t": "n", "v": 20},
    "D18": {"t": "n", "v": 10},
    "E18": {"t": "n", "v": 100},
    "F18": {"t": "n", "v": 200},
    "G18": {"t": "n", "v": 300},
    "H18": {"t": "f", "f": "SUMIF(B18:D18,10,E18:G18)"},

    "A20": {"t": "s", "v": "--- COUNTIF ---"},
    "B20": {"t": "n", "v": 10},
    "C20": {"t": "n", "v": 20},
    "D20": {"t": "n", "v": 10},
    "E20": {"t": "n", "v": 30},
    "F20": {"t": "n", "v": 10},
    "G20": {"t": "s", "v": "10の個数"},
    "H20": {"t": "f", "f": "COUNTIF(B20:F20,10)"}
  }
}
