{
  "name": "ComputeLookupSample",
  "cells": {
    "A1": {"t": "s", "v": "json2xlsx --compute 検索/選択関数サンプル"},

    "A3": {"t": "s", "v": "--- CHOOSE ---"},
    "A4": {"t": "s", "v": "インデックス選択"},
    "B4": {"t": "f", "f": "CHOOSE(1,10,20,30)"},
    "C4": {"t": "f", "f": "CHOOSE(2,10,20,30)"},
    "D4": {"t": "f", "f": "CHOOSE(3,10,20,30)"},

    "A6": {"t": "s", "v": "--- VLOOKUP ---"},
    "A7": {"t": "s", "v": "商品一覧"},
    "B7": {"t": "n", "v": 101},
    "C7": {"t": "n", "v": 10},
    "B8": {"t": "n", "v": 102},
    "C8": {"t": "n", "v": 20},
    "B9": {"t": "n", "v": 103},
    "C9": {"t": "n", "v": 30},
    "A10": {"t": "s", "v": "商品101の単価"},
    "D10": {"t": "f", "f": "VLOOKUP(101,B7:C9,2)"},
    "A11": {"t": "s", "v": "商品103の単価"},
    "D11": {"t": "f", "f": "VLOOKUP(103,B7:C9,2)"},

    "A13": {"t": "s", "v": "--- INDEX ---"},
    "A14": {"t": "s", "v": "1次元（縦範囲）"},
    "B14": {"t": "n", "v": 100},
    "B15": {"t": "n", "v": 200},
    "B16": {"t": "n", "v": 300},
    "D14": {"t": "s", "v": "2番目"},
    "E14": {"t": "f", "f": "INDEX(B14:B16,2)"},
    "A18": {"t": "s", "v": "2次元"},
    "B18": {"t": "n", "v": 10},
    "C18": {"t": "n", "v": 100},
    "B19": {"t": "n", "v": 20},
    "C19": {"t": "n", "v": 200},
    "B20": {"t": "n", "v": 30},
    "C20": {"t": "n", "v": 300},
    "E18": {"t": "s", "v": "2行2列"},
    "F18": {"t": "f", "f": "INDEX(B18:C20,2,2)"},
    "E19": {"t": "s", "v": "3行1列"},
    "F19": {"t": "f", "f": "INDEX(B18:C20,3,1)"},

    "A22": {"t": "s", "v": "--- MATCH ---"},
    "A23": {"t": "s", "v": "検索"},
    "B23": {"t": "n", "v": 10},
    "C23": {"t": "n", "v": 20},
    "D23": {"t": "n", "v": 30},
    "E23": {"t": "n", "v": 20},
    "F23": {"t": "s", "v": "20の位置"},
    "G23": {"t": "f", "f": "MATCH(20,B23:E23,0)"},
    "F24": {"t": "s", "v": "30の位置"},
    "G24": {"t": "f", "f": "MATCH(30,B23:E23,0)"},

    "A26": {"t": "s", "v": "--- XLOOKUP ---"},
    "A27": {"t": "s", "v": "検索配列"},
    "B27": {"t": "n", "v": 101},
    "C27": {"t": "n", "v": 102},
    "D27": {"t": "n", "v": 103},
    "E27": {"t": "s", "v": "戻り配列"},
    "F27": {"t": "n", "v": 1000},
    "G27": {"t": "n", "v": 2000},
    "H27": {"t": "n", "v": 3000},
    "A28": {"t": "s", "v": "101 の値"},
    "I28": {"t": "f", "f": "XLOOKUP(101,B27:D27,F27:H27)"},
    "A29": {"t": "s", "v": "103 の値"},
    "I29": {"t": "f", "f": "XLOOKUP(103,B27:D27,F27:H27)"},
    "A30": {"t": "s", "v": "999（デフォルト-1）"},
    "I30": {"t": "f", "f": "XLOOKUP(999,B27:D27,F27:H27,-1)"},
    "A31": {"t": "s", "v": "Note: XLOOKUP は Office 365 (2020) / Excel 2021 以降の関数です．古いバージョンでは利用できません．"}
  }
}
